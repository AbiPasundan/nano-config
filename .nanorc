############################################
# NANO CONFIGURATION (~/.nanorc)
############################################

# --- SYNTAX HIGHLIGHTING ---
############################################
# Load all built-in syntax highlighting files of nano.
include "/usr/share/nano/*.nanorc"

# For macOS (nano from Homebrew) – Uncomment if using macOS
# include "/opt/homebrew/share/nano/*.nanorc"


# --- NAVIGATION & CURSOR BEHAVIOR ---
############################################
# The Home key moves to the beginning of the text first, then to the first column.
set smarthome

# Save the last cursor position when the file is reopened.
set positionlog

# Cursor stops at the end of the text when navigating lines.
set afterends

# Display scroll position indicator on the right side.
set indicator

# --- EDITING BEHAVIOR ---
############################################
# Auto-indent follows the previous line.
set autoindent

# Indent using 4 spaces.
set tabsize 4

# Convert TAB to spaces.
set tabstospaces

# Keep indentation neat in empty areas.
set atblanks

# Remove trailing whitespace on save.
set trimblanks

# Cut starts from the cursor position (not the entire line).
set cutfromcursor

# --- VISUAL & READABILITY ---
############################################
# Show number of column
set linenumbers

# Minimalist status bar mode (includes cursor position).
set minibar

# Highlight matching brackets (using built-in reverse video).
set matchbrackets "(<[{)>]}"

# Display whitespace (spaces & tabs).
set whitespace "»·"

# Highlight column 100 (coding ruler).
set guidestripe 100

# Render text bold if the terminal supports it.
set boldtext

# Wrap long teks to the next column
set softwrap

# Scroll more supports
# set smooth

# --- COLOR CONFIGURATION ---
############################################
# Color of title bar
set titlecolor white,blue

# Color number column
set numbercolor yellow

# Color of status bar
set statuscolor black,cyan

# Color of error message
set errorcolor brightwhite,red

# Color first prompt search
set promptcolor black,green

# Color selection text
set selectedcolor black,white

# --- PRODUCTIVITY ---
############################################
# Save search history.
set historylog

# Open multiple files simultaneously (multi-buffer).
set multibuffer

# Enable mouse support (click to move cursor).
set mouse

############################################
# --- KEY BINDINGS ---
############################################
# Ctrl+S → Save file
bind ^S savefile main

# Ctrl+F → Search
bind ^F whereis main

# Ctrl+Z → Undo
bind ^Z undo main

# Ctrl+Y → Redo
bind ^Y redo main

# Ctrl+Q → Exit nano
bind ^Q exit all

# Ctrl+H → Replace text
bind ^H replace main

# Ctrl+C → Copy
bind ^C copy main

# Ctrl+X → Cut
bind ^X cut main

# Ctrl+V → Paste
bind ^V paste main
